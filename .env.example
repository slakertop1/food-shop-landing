# --- Магазин ---
SHOP_NAME=Лавка вкуса
MIN_ORDER=1500
CURRENCY=RUB
# Публичный адрес сайта (для ссылок возврата с оплаты и вебхука)
BASE_URL=http://localhost:8000

# --- ЮKassa (эквайринг) ---
# Пусто = ДЕМО-режим оплаты (без реальных списаний, для показа заказчику).
# Боевые ключи: ЛК ЮKassa -> Настройки -> Ключи API. Нужно ИП/ООО.
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# --- Уведомления о заказах ---
# Email (SMTP). Пусто = заказы просто пишутся в лог.
ORDER_EMAIL=orders@example.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
# Дубль заказа в Telegram (по желанию)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Админ ---
# Токен для включения/выключения продаж (смените на свой!)
ADMIN_TOKEN=change-me

DB_PATH=data/shop.db
